  "script": "async function googleTranslate(t,n,o,e,a){let s=(await e.get(`https://translate.google.com/translate_a/single?dt=at&dt=bd&dt=ex&dt=ld&dt=md&dt=qca&dt=rw&dt=rm&dt=ss&dt=t&${function t(n){let o=[];for(let e in n)if(n.hasOwnProperty(e)){let a=n[e],s=encodeURIComponent(e),i=encodeURIComponent(a);o.push(`${s}=${i}`)}return o.join(\"&\")}({client:\"gtx\",sl:n,tl:o,hl:o,ie:\"UTF-8\",oe:\"UTF-8\",otf:\"1\",ssel:\"0\",tsel:\"0\",kc:\"7\",q:t})}`,{headers:{\"content-type\":\"application/json\"}})).data;if(s[1]){let i={pronunciations:[],explanations:[],associations:[],sentence:[],audios:[]};for(let l of(s[0][1][3]&&i.pronunciations.push({symbol:s[0][1][3],voice:\"\"}),s[1]))i.explanations.push({trait:l[0],explains:l[2].map(t=>t[0])});if(s[13])for(let p of s[13][0])i.sentence.push({source:p[0]});return i}{let r=\"\";for(let c of s[0])c[0]&&(r+=c[0]);return r.trim()}}async function getDictText(t,n,o,e,a,s){let i=await googleTranslate(t,n,o,e,s);return i.explanations?(window.learnMoreUrl=\"https://www.google.com/search?q=define+\"+t,`<p class=\"dict-word-type\">[${a(\"Pronunciations\")}]</p></p>`+i.pronunciations.map(t=>`<span style=\"font-weight: bold\">${t.region?t.region:\"\"}</span> [${t.symbol}]`).join(\" \")+i.audios.map(t=>`<br/><div class=\"audio-container\"><audio controls class=\"audio-player\" controlsList=\"nodownload noplaybackrate\"><source src=\"${t.url}\" type=\"audio/mpeg\"></audio></div></p>`)+`<p class=\"dict-word-type\">[${a(\"Explanations\")}]</p>`+i.explanations.map(t=>`<p><span style=\"font-weight: bold\">${t.trait}</span> ${t.explains.join(\", \")}</p>`).join(\"\")+`<p class=\"dict-word-type\">[${a(\"Associations\")}]</p></p>`+i.associations.map(t=>t).join(\", \")+`<p class=\"dict-word-type\">[${a(\"Sentence\")}]</p><ul>`+i.sentence.map(t=>`<li>${t.source}${t.translation?\" \"+t.translation:\"\"}</li>`).join(\"\")+\"</ul>\"+`<p class=\"dict-learn-more\">${a(\"Learn more\")}</p>`):`<p>${i}</p>`}window.getDictText=getDictText;"
